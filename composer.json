{
  "name": "aurix/core",
  "description": "Custom authentication and RBAC foundation for Laravel applications.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "illuminate/cache": "^10.0|^11.0|^12.0",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "illuminate/database": "^10.0|^11.0|^12.0",
    "illuminate/auth": "^10.0|^11.0|^12.0",
    "illuminate/routing": "^10.0|^11.0|^12.0",
    "laravel/socialite": "^5.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0|^10.0",
    "phpunit/phpunit": "^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "Aurix\\": "src/",
      "Aurix\\Database\\Seeders\\": "database/seeders/"
    },
    "classmap": [
      "src/Legacy/LaraAuthServiceProvider.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Aurix\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Aurix\\AurixServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
